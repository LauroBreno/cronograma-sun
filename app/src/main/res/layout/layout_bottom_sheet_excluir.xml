<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:backgroundTint="@color/bege_fundo"
    android:orientation="vertical"
    android:padding="24dp">

    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="16dp"
        android:background="#D7CCC8" />

    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="8dp">

        <ImageView
            android:id="@+id/btnFecharDel"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:padding="4dp"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:tint="#BCAAA4" />

        <TextView
            android:id="@+id/lblTituloDelForm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"
            android:text="Excluir Matéria"
            android:textColor="@color/marrom_escuro"
            android:textSize="20sp"
            android:textStyle="bold" />
    </RelativeLayout>

    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/lottieCatDel"
        android:layout_width="70dp"
        android:layout_height="70dp"
        android:layout_gravity="end"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="-21dp"
        android:elevation="4dp"
        app:lottie_autoPlay="true"
        app:lottie_loop="true"
        app:lottie_rawRes="@raw/loader_cat" />

    <com.google.android.material.card.MaterialCardView
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:layout_marginBottom="24dp"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp"
        app:strokeColor="#E0E0E0"
        app:strokeWidth="1dp">

        <LinearLayout
            android:id="@+id/toggleGroupDelete"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="horizontal">

            <TextView
                android:id="@+id/btnDelToggleMateria"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="#D9534F"
                android:gravity="center"
                android:text="Matéria"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:textStyle="bold" />

            <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#E0E0E0" />

            <TextView
                android:id="@+id/btnDelToggleAssunto"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:gravity="center"
                android:text="Assunto"
                android:textColor="#8D7B73"
                android:textSize="12sp" />

            <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#E0E0E0" />

            <TextView
                android:id="@+id/btnDelToggleRevisao"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:gravity="center"
                android:text="Revisões"
                android:textColor="#8D7B73"
                android:textSize="12sp" />

            <View android:layout_width="1dp" android:layout_height="match_parent" android:background="#E0E0E0" />

            <TextView
                android:id="@+id/btnDelToggleNota"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:background="@android:color/transparent"
                android:gravity="center"
                android:text="Nota"
                android:textColor="#8D7B73"
                android:textSize="12sp" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>

    <LinearLayout
        android:id="@+id/layoutDelMateria"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="visible">

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:boxCornerRadiusBottomEnd="16dp"
            app:boxCornerRadiusBottomStart="16dp"
            app:boxCornerRadiusTopEnd="16dp"
            app:boxCornerRadiusTopStart="16dp"
            app:boxBackgroundColor="@color/bege_fundo"
            app:boxStrokeColor="@color/marrom_texto_claro"
            app:hintTextColor="#D9534F"
            app:endIconTint="@color/marrom_escuro"
            android:hint="Matéria para Excluir">
            <AutoCompleteTextView
                android:id="@+id/autoCompleteDelMateria"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:paddingVertical="16dp"
                android:textColor="@color/marrom_escuro"
                android:popupBackground="@drawable/shape_dropdown_popup"/>
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Aviso: Apagar a matéria exclui todos os assuntos, notas e revisões associados a ela permanentemente."
            android:textColor="#D9534F"
            android:textSize="12sp"
            android:layout_marginBottom="16dp"
            android:textAlignment="center"/>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutDelAssunto"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:boxCornerRadiusBottomEnd="16dp"
            app:boxCornerRadiusBottomStart="16dp"
            app:boxCornerRadiusTopEnd="16dp"
            app:boxCornerRadiusTopStart="16dp"
            app:boxBackgroundColor="@color/bege_fundo"
            app:boxStrokeColor="@color/marrom_texto_claro"
            app:hintTextColor="@color/marrom_escuro"
            app:endIconTint="@color/marrom_escuro"
            android:hint="Matéria">
            <AutoCompleteTextView
                android:id="@+id/autoCompleteDelMatAssunto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:paddingVertical="16dp"
                android:textColor="@color/marrom_escuro"
                android:popupBackground="@drawable/shape_dropdown_popup"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:boxCornerRadiusBottomEnd="16dp"
            app:boxCornerRadiusBottomStart="16dp"
            app:boxCornerRadiusTopEnd="16dp"
            app:boxCornerRadiusTopStart="16dp"
            app:boxBackgroundColor="@color/bege_fundo"
            app:boxStrokeColor="@color/marrom_texto_claro"
            app:hintTextColor="#D9534F"
            app:endIconTint="@color/marrom_escuro"
            android:hint="Assunto para Excluir">
            <AutoCompleteTextView
                android:id="@+id/autoCompleteDelAssunto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:paddingVertical="16dp"
                android:textColor="@color/marrom_escuro"
                android:popupBackground="@drawable/shape_dropdown_popup"/>
        </com.google.android.material.textfield.TextInputLayout>
    </LinearLayout>

    <LinearLayout
        android:id="@+id/layoutDelListas"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:visibility="gone">

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:boxCornerRadiusBottomEnd="16dp"
            app:boxCornerRadiusBottomStart="16dp"
            app:boxCornerRadiusTopEnd="16dp"
            app:boxCornerRadiusTopStart="16dp"
            app:boxBackgroundColor="@color/bege_fundo"
            app:boxStrokeColor="@color/marrom_texto_claro"
            app:hintTextColor="@color/marrom_escuro"
            app:endIconTint="@color/marrom_escuro"
            android:hint="Matéria">
            <AutoCompleteTextView
                android:id="@+id/autoCompleteDelListMat"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:paddingVertical="16dp"
                android:textColor="@color/marrom_escuro"
                android:popupBackground="@drawable/shape_dropdown_popup"/>
        </com.google.android.material.textfield.TextInputLayout>

        <com.google.android.material.textfield.TextInputLayout
            style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            app:boxCornerRadiusBottomEnd="16dp"
            app:boxCornerRadiusBottomStart="16dp"
            app:boxCornerRadiusTopEnd="16dp"
            app:boxCornerRadiusTopStart="16dp"
            app:boxBackgroundColor="@color/bege_fundo"
            app:boxStrokeColor="@color/marrom_texto_claro"
            app:hintTextColor="@color/marrom_escuro"
            app:endIconTint="@color/marrom_escuro"
            android:hint="Assunto">
            <AutoCompleteTextView
                android:id="@+id/autoCompleteDelListAss"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="none"
                android:paddingVertical="16dp"
                android:textColor="@color/marrom_escuro"
                android:popupBackground="@drawable/shape_dropdown_popup"/>
        </com.google.android.material.textfield.TextInputLayout>

        <TextView
            android:id="@+id/txtStatusDelete"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Selecione um assunto."
            android:textColor="#8D7B73"
            android:textSize="14sp"
            android:layout_marginBottom="8dp"
            android:textAlignment="center"/>

        <LinearLayout
            android:id="@+id/containerListaDelete"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginBottom="8dp"/>
    </LinearLayout>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnConfirmarExclusao"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:backgroundTint="#D9534F"
        android:text="Excluir Definitivamente"
        android:textColor="@color/white"
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="16dp" />

</LinearLayout>