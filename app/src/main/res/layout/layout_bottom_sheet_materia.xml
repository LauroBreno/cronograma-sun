<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@color/bege_fundo"
    android:orientation="vertical">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingHorizontal="24dp"
        android:paddingTop="24dp"
        android:paddingBottom="16dp">

        <ImageView
            android:id="@+id/btnFecharMateria"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/marrom_texto_claro" />

        <TextView
            android:id="@+id/lblTituloForm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Nova Matéria"
            android:textColor="@color/marrom_escuro"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:clipToPadding="false"
        android:paddingHorizontal="24dp"
        android:paddingBottom="24dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:clipChildren="false">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:clipChildren="false"
                android:layout_marginTop="8dp">

                <com.google.android.material.button.MaterialButtonToggleGroup
                    android:id="@+id/toggleGroupMateriaAssunto"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    app:checkedButton="@id/btnToggleMateria"
                    app:singleSelection="true"
                    app:selectionRequired="true">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnToggleMateria"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Matéria"
                        app:backgroundTint="@android:color/transparent"
                        app:strokeColor="@color/marrom_texto_claro" />

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/btnToggleAssunto"
                        style="@style/Widget.Material3.Button.OutlinedButton"
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="Assunto"
                        app:backgroundTint="@android:color/transparent"
                        app:strokeColor="@color/marrom_texto_claro" />
                </com.google.android.material.button.MaterialButtonToggleGroup>

                <com.airbnb.lottie.LottieAnimationView
                    android:id="@+id/lottieCatForm"
                    android:layout_width="70dp"
                    android:layout_height="70dp"
                    android:layout_alignTop="@id/toggleGroupMateriaAssunto"
                    android:layout_alignEnd="@id/toggleGroupMateriaAssunto"
                    android:layout_marginTop="-45dp"
                    android:layout_marginEnd="16dp"
                    android:elevation="5dp"
                    app:lottie_autoPlay="true"
                    app:lottie_loop="true"
                    app:lottie_rawRes="@raw/loader_cat" />
            </RelativeLayout>

            <LinearLayout
                android:id="@+id/layoutFormMateria"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp">

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Nome da Matéria"
                    app:boxBackgroundColor="@color/bege_fundo"
                    app:boxCornerRadiusBottomEnd="16dp"
                    app:boxCornerRadiusBottomStart="16dp"
                    app:boxCornerRadiusTopEnd="16dp"
                    app:boxCornerRadiusTopStart="16dp"
                    app:boxStrokeColor="@color/marrom_texto_claro"
                    app:hintTextColor="@color/marrom_escuro">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/inputNomeMateria"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/marrom_escuro" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:hint="Meta da Nota (Ex: 7.5)"
                    app:boxBackgroundColor="@color/bege_fundo"
                    app:boxCornerRadiusBottomEnd="16dp"
                    app:boxCornerRadiusBottomStart="16dp"
                    app:boxCornerRadiusTopEnd="16dp"
                    app:boxCornerRadiusTopStart="16dp"
                    app:boxStrokeColor="@color/marrom_texto_claro"
                    app:hintTextColor="@color/marrom_escuro">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/inputMetaMateria"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="numberDecimal"
                        android:textColor="@color/marrom_escuro" />
                </com.google.android.material.textfield.TextInputLayout>
            </LinearLayout>

            <LinearLayout
                android:id="@+id/layoutFormAssunto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:layout_marginTop="16dp"
                android:visibility="gone">

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Vincular à Matéria"
                    app:boxBackgroundColor="@color/bege_fundo"
                    app:boxCornerRadiusBottomEnd="16dp"
                    app:boxCornerRadiusBottomStart="16dp"
                    app:boxCornerRadiusTopEnd="16dp"
                    app:boxCornerRadiusTopStart="16dp"
                    app:boxStrokeColor="@color/marrom_texto_claro"
                    app:hintTextColor="@color/marrom_escuro"
                    app:endIconTint="@color/marrom_escuro">

                    <AutoCompleteTextView
                        android:id="@+id/autoCompleteVinculoMateria"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"
                        android:paddingVertical="16dp"
                        android:textColor="@color/marrom_escuro"
                        android:popupBackground="@drawable/shape_dropdown_popup" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:hint="Nome do Assunto"
                    app:boxBackgroundColor="@color/bege_fundo"
                    app:boxCornerRadiusBottomEnd="16dp"
                    app:boxCornerRadiusBottomStart="16dp"
                    app:boxCornerRadiusTopEnd="16dp"
                    app:boxCornerRadiusTopStart="16dp"
                    app:boxStrokeColor="@color/marrom_texto_claro"
                    app:hintTextColor="@color/marrom_escuro">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/inputNomeAssunto"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:textColor="@color/marrom_escuro" />
                </com.google.android.material.textfield.TextInputLayout>

                <com.google.android.material.textfield.TextInputLayout
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:hint="Quantidade de Revisões"
                    app:boxBackgroundColor="@color/bege_fundo"
                    app:boxCornerRadiusBottomEnd="16dp"
                    app:boxCornerRadiusBottomStart="16dp"
                    app:boxCornerRadiusTopEnd="16dp"
                    app:boxCornerRadiusTopStart="16dp"
                    app:boxStrokeColor="@color/marrom_texto_claro"
                    app:hintTextColor="@color/marrom_escuro"
                    app:endIconTint="@color/marrom_escuro">

                    <AutoCompleteTextView
                        android:id="@+id/autoCompleteQtdRevisoes"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="none"
                        android:paddingVertical="16dp"
                        android:textColor="@color/marrom_escuro"
                        android:popupBackground="@drawable/shape_dropdown_popup" />
                </com.google.android.material.textfield.TextInputLayout>

                <LinearLayout
                    android:id="@+id/containerDatasRevisoes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginTop="8dp">
                </LinearLayout>

            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="16dp">

                <TextView
                    android:id="@+id/btnAdicionarNovaMateria"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginEnd="32dp"
                    android:background="?attr/selectableItemBackground"
                    android:padding="8dp"
                    android:text="+ Adicionar Nova Matéria"
                    android:textColor="@color/marrom_texto_claro"
                    android:textSize="14sp"
                    android:textStyle="bold" />

                <TextView
                    android:id="@+id/btnAdicionarNovoAssunto"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="?attr/selectableItemBackground"
                    android:padding="8dp"
                    android:text="+ Adicionar Novo Assunto"
                    android:textColor="@color/marrom_texto_claro"
                    android:textSize="14sp"
                    android:textStyle="bold" />
            </LinearLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnConfirmarCadastro"
                android:layout_width="match_parent"
                android:layout_height="60dp"
                android:layout_marginTop="32dp"
                android:text="Confirmar Matéria / Assunto"
                android:textColor="@color/white"
                android:textSize="16sp"
                android:textStyle="bold"
                app:backgroundTint="@color/marrom_escuro"
                app:cornerRadius="32dp" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</LinearLayout>