<resources xmlns:tools="http://schemas.android.com/tools">
    <style name="Base.Theme.CronogramaSun" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:statusBarColor">@color/bege_fundo</item>
        <item name="android:windowLightStatusBar">true</item>
        <item name="colorPrimary">@color/marrom_escuro</item>
        <item name="android:textColorHighlight">#4D584039</item>
    </style>

    <style name="Theme.CronogramaSun" parent="Base.Theme.CronogramaSun" />

    <style name="BotaoMarromDialog" parent="Widget.AppCompat.Button.ButtonBar.AlertDialog">
        <item name="android:textColor">@color/marrom_escuro</item>
    </style>

    <style name="TemaCalendarioSun" parent="Theme.AppCompat.Light.Dialog">
        <item name="colorAccent">@color/marrom_escuro</item>
        <item name="android:colorBackground">@color/bege_fundo</item>
        <item name="android:textColorPrimary">@color/marrom_escuro</item>
        <item name="buttonBarPositiveButtonStyle">@style/BotaoMarromDialog</item>
        <item name="android:headerBackground">@color/marrom_escuro</item>
        <item name="android:colorAccent">@color/marrom_escuro</item>
        <item name="buttonBarNegativeButtonStyle">@style/BotaoMarromDialog</item>
    </style>

    <style name="TemaAlertaSun" parent="Theme.AppCompat.Light.Dialog.Alert">
        <item name="colorAccent">@color/marrom_escuro</item>
        <item name="android:colorBackground">@color/bege_fundo</item>
        <item name="android:textColorPrimary">@color/marrom_escuro</item>
        <item name="buttonBarPositiveButtonStyle">@style/BotaoMarromDialog</item>
        <item name="colorPrimary">@color/marrom_escuro</item>
        <item name="android:colorPrimary">@color/marrom_escuro</item>
        <item name="buttonBarNegativeButtonStyle">@style/BotaoMarromDialog</item>
    </style>

    <style name="TemaMenuFlutuante" parent="Theme.AppCompat.Light">
        <item name="android:popupBackground">@color/bege_fundo</item>
        <item name="android:textColorPrimary">@color/marrom_escuro</item>
    </style>
</resources>